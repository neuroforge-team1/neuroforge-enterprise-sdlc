{
  "info": {
    "name": "NeuroForge Nexus - Milestone 1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Get Token (Keycloak) + Users, Projects, Teams, DevOps endpoints. Import alongside a Postman environment defining baseUrl, keycloakBaseUrl, username, password, token."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token (Keycloak - password grant, dev only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id", "value": "nexus-frontend" },
                { "key": "username", "value": "{{username}}" },
                { "key": "password", "value": "{{password}}" }
              ]
            },
            "url": "{{keycloakBaseUrl}}/realms/neuroforge-nexus/protocol/openid-connect/token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('token', json.access_token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get current user (syncs profile mirror)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "List all users (PROJECT_MANAGER/ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users"
          }
        }
      ]
    },
    {
      "name": "Teams",
      "item": [
        {
          "name": "Create team",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Platform Core Team\"\n}" },
            "url": "{{baseUrl}}/api/teams"
          }
        },
        {
          "name": "List teams",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/teams"
          }
        },
        {
          "name": "Add member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"REPLACE_WITH_USER_ID\"\n}" },
            "url": "{{baseUrl}}/api/teams/REPLACE_WITH_TEAM_ID/members"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"FinCore Nexus\",\n  \"description\": \"Milestone 1 pilot project\",\n  \"teamId\": null,\n  \"milestoneDueDate\": \"2026-08-20\"\n}"
            },
            "url": "{{baseUrl}}/api/projects"
          }
        },
        {
          "name": "List projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/projects"
          }
        },
        {
          "name": "Get project by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/projects/REPLACE_WITH_PROJECT_ID"
          }
        },
        {
          "name": "Update project",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"FinCore Nexus\",\n  \"description\": \"Updated description\",\n  \"status\": \"ON_HOLD\",\n  \"teamId\": null,\n  \"milestoneDueDate\": \"2026-09-01\"\n}"
            },
            "url": "{{baseUrl}}/api/projects/REPLACE_WITH_PROJECT_ID"
          }
        },
        {
          "name": "Delete project (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/projects/REPLACE_WITH_PROJECT_ID"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/dashboard/summary"
          }
        }
      ]
    },
    {
      "name": "DevOps",
      "item": [
        {
          "name": "Health stub (DEVOPS_ENGINEER/ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/devops/health"
          }
        }
      ]
    }
  ]
}
